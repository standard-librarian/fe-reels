# Origin of the Reels API — no trailing path, since endpoints already start
# with /api/v1/reels/. This is the only place the base URL is configured.
#
# Local dev points at staging (below). The deployment workflow supplies this at
# build time: staging gets the same origin, production leaves it EMPTY so the
# app calls its own origin with relative paths.
VITE_API_BASE_URL=https://staging-services.q84sale.com

# Favorites (wishlist) writes go to the 4Sale services API with a signed
# X-Custom-Authorization challenge. Auth is TEST-ONLY static values for now
# (a device id + bearer token) until this is merged into the real web app.
# Must match the environment the feed comes from (VITE_API_BASE_URL above),
# else addFavorite returns "No Records Found" for feed listings.
VITE_FAVORITES_API_URL=https://staging-services.q84sale.com/live/index.php
VITE_FAVORITES_API_SECRET=
VITE_FAVORITES_DEVICE_ID=
VITE_FAVORITES_TOKEN=

# Amplitude analytics. Leave the key EMPTY to disable analytics entirely (the app
# runs normally; events log to the console in dev only). Get the client/browser
# key from Amplitude → Settings → Projects → [your project] → API Key.
# Session Replay uses this same key — just enable Session Replay on the project.
VITE_AMPLITUDE_API_KEY=
# Fraction of sessions that get a replay recording, 0..1 (default 0.1 = 10%).
VITE_AMPLITUDE_SR_SAMPLE_RATE=
