# Base URL for the Reels API. Leave empty to use the same origin, which the
# MSW mock backend intercepts in dev. Staging builds use
# https://staging-services.q84sale.com via the deployment workflow. Reels
# endpoints are rooted at /api/v1/reels/.
VITE_API_BASE_URL=

# Set to true only when you want MSW fixtures instead of the live API (dev only).
VITE_API_MOCK=false
