# Origin of the Reels API — no trailing path, since endpoints already start
# with /api/v1/reels/. This is the only place the base URL is configured.
#
# Local dev points at staging (below). The deployment workflow supplies this at
# build time: staging gets the same origin, production leaves it EMPTY so the
# app calls its own origin with relative paths.
VITE_API_BASE_URL=https://staging-services.q84sale.com
